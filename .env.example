# ============================================================
# NOVA — Dorm Room AI Assistant — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your API keys.
# Lines starting with # are comments. Only uncomment what you need.

# === LLM (Required) ===
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# === ElevenLabs TTS/STT (Required for voice) ===
ELEVEN_API_KEY=your_elevenlabs_api_key_here
ELEVEN_VOICE_ID=your_voice_id_here
# ELEVEN_STT_MODEL=scribe_v2_realtime

# === Whisper STT (local GPU — Required for voice) ===
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16
# WHISPER_VOCAB_PROMPT=Jarvis, Nova, Hey Jarvis, calorie, calories, dorm room

# === Google OAuth (Gmail + Calendar) ===
# Get credentials at https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your_client_secret
# GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# === Microsoft Graph (Outlook) ===
# MS_TENANT_ID=your_tenant_id
# MS_CLIENT_ID=your_client_id
# MS_CLIENT_SECRET=your_client_secret
# MS_REDIRECT_URI=http://localhost:8000/auth/outlook/callback

# === Slack ===
# SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# === Speaker Verification ===
SPEAKER_VERIFY_THRESHOLD=0.65

# === Server ===
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DATABASE_PATH=data/assistant.db
AUDIT_LOG_PATH=data/audit.log

# === Client ===
SERVER_WS_URL=ws://localhost:8000/ws/client

# === Weather (OpenWeatherMap free tier) ===
# OPENWEATHERMAP_API_KEY=your_owm_api_key_here

# === Spotify ===
# SPOTIFY_ACCESS_TOKEN=your_spotify_token_here

# === MQTT (for IoT devices) ===
# MQTT_BROKER_HOST=localhost
# MQTT_BROKER_PORT=1883
# MQTT_USERNAME=
# MQTT_PASSWORD=
# MQTT_TOPIC_PREFIX=nova

# === Home Assistant ===
# HA_URL=http://homeassistant.local:8123
# HA_TOKEN=your_long_lived_access_token_here

# === Personality ===
ASSISTANT_NAME=NOVA
